    "movies",
    "tv",
    "series",
    "iptv",
    "streaming",
    "video",
    "player",
    "entertainment"
  ],
  "author": "Your Name",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/yourusername/lampa-entertainment-plugin.git"
  },
  "bugs": {
    "url": "https://github.com/yourusername/lampa-entertainment-plugin/issues"
  },
  "homepage": "https://github.com/yourusername/lampa-entertainment-plugin#readme",
  "devDependencies": {
    "@babel/core": "^7.22.0",
    "@babel/preset-env": "^7.22.0",
    "babel-loader": "^9.1.0",
    "eslint": "^8.40.0",
    "jest": "^29.5.0",
    "jsdoc": "^4.0.0",
    "webpack": "^5.85.0",
    "webpack-cli": "^5.1.0"
  },
  "dependencies": {},
  "engines": {
    "node": ">=14.0.0"
  },
  "files": [
    "lampa-plugin.js",
    "lampa-plugin.css",
